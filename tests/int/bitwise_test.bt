fun test_bitwise_operators() {
	a := 0b1001
	b := 0b0011

	assert ~a == -10
	assert a & b == 0b0001
	assert a | b == 0b1011
	assert a ^ b == 0b1010

	assert a << 2 == 0b100100
	assert a >> 2 == 0b10
}

fun test_bitwise_u32() {
	a := 0b11101101101110001000001100100000 as u32 // 3988292384
	b := 0b1110110110111000100000110010000 as u32 // 1994146192
	assert a >> 1 == b
}

// Verify bitwise not on u32 stays within u32 bounds.
fun test_unsigned_not() {
	zero := 0 as u32
	one := 1 as u32

	assert ~zero == MAX_U32
	assert ~one == (MAX_U32 - 1)
}
