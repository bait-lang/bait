// TODO C array.insert()
fun test_array_filter() {
	// From https://github.com/bait-lang/bait/issues/13
	args := ['a.txt', 'b.md', 'c.md']
	md_files := args.filter(fun (a string) bool {
		return a.ends_with(".md")
	})
	assert md_files.length == 2
	assert typeof(md_files) == "[]string"
}
