import os

fun test_dir(){
	l := '/foo/bar/file'
	assert os.dir(l) == '/foo/bar'

	w := 'C:\\foo\\bar\\file'
	assert os.dir(w) == 'C:\\foo\\bar'
}

fun test_read_file() {
	content := os.read_file("${$BAITDIR}/lib/os/testdata/3_lines.txt")
	normalized := content.replace('\r\n', '\n')
	assert normalized == '1\n2\n3\n'
}

fun test_read_lines() {
	lines := os.read_lines("${$BAITDIR}/lib/os/testdata/3_lines.txt")
	assert lines.length == 3
	assert lines[1] == '2'
}

fun test_exists_dir() {
	assert os.exists_dir("${$BAITDIR}/lib")
	assert not os.exists_dir("${$BAITDIR}/README.md")
	assert not os.exists_dir('i/hope/this/never/exists/anywhere')
}

fun test_getenv_missing_returns_empty() {
	key := 'BAIT_TEST_ENV_MISSING_${$LINE}'
	assert os.getenv(key) == ''
}

fun test_setenv_getenv_roundtrip() {
	key := 'BAIT_TEST_ENV_ROUNDTRIP_${$LINE}'
	value := 'roundtrip_ok'
	os.setenv(key, value)
	assert os.getenv(key) == value
}

fun test_setenv_overwrite() {
	key := 'BAIT_TEST_ENV_OVERWRITE_${$LINE}'
	os.setenv(key, 'first')
	os.setenv(key, 'second')
	assert os.getenv(key) == 'second'
}
