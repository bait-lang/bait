fun test_floats() {
	f := 1.23
	assert f == 1.23
}

fun test_str_precision() {
	// Not precicely storable but should be round-tripped
	// TODO fix on C backend
	// f1 := 3.14
	// assert f1.str() == '3.14'

	// Precision of 17 decimals in output
	f2 := 123.45678901234567890
	assert f2.str() == '123.45678901234568'
}
