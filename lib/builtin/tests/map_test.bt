fun test_type_init() {
	mut m := map[string]string
	m['a'] = 'A'
	m['b'] = 'B'

	assert m.length == 2
	assert m['b'] == 'B'

	m['c'] = 'C'
	assert m.keys() == ['a', 'b', 'c']
}

fun test_literal_init() {
	m := map{
		'a': 'A'
		'b': 'B'
	}

	assert m.length == 2
	assert m['b'] == 'B'
}
