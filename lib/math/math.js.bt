package math

pub fun ceil(x f64) f64 {
	return #JS.'Math.ceil(x)' as f64
}

pub fun log2(x f64) f64 {
	return #JS.'Math.log2(x)' as f64
}

pub fun pow(base f64, exponent f64) f64 {
	return #JS.'Math.pow(base, exponent)' as f64
}
